# ===========================================================================
# Sispubli API — Variáveis de Ambiente
# ===========================================================================
# Copie este arquivo para .env e preencha os valores.
#
#   cp .env.example .env
#
# IMPORTANTE: O arquivo .env contém segredos e NUNCA deve ser commitado.
# Ele já está listado no .gitignore.
# ===========================================================================

# ---------------------------------------------------------------------------
# CPF_TESTE (obrigatório apenas para testes E2E)
# ---------------------------------------------------------------------------
# Um CPF válido de 11 dígitos, usado EXCLUSIVAMENTE pela suíte de testes
# de integração (pytest -m e2e) para validar a conexão real com o Sispubli.
#
# ⚠️  NÃO é necessário para testes unitários (make test).
# ⚠️  NÃO é necessário para rodar o servidor localmente (make serve).
# ⚠️  NUNCA insira este valor no código-fonte ou em commits.
#
# Exemplo (use o seu CPF real apenas localmente):
CPF_TESTE=00000000000

# ---------------------------------------------------------------------------
# HASH_SALT (obrigatório em produção)
# ---------------------------------------------------------------------------
# Salt secreto usado para gerar os IDs únicos dos certificados via SHA-256.
# Em produção (ENVIRONMENT=production), o servidor NÃO sobe sem este valor.
#
# Gere um salt forte, por exemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
HASH_SALT=troque_por_um_salt_secreto_forte

# ---------------------------------------------------------------------------
# ENVIRONMENT (opcional)
# ---------------------------------------------------------------------------
# Define o modo de execução da API.
# Valores: "development" (padrão) | "production"
#
# Em "production", o HASH_SALT é validado no startup (Fail Fast).
#
# ENVIRONMENT=development
